---
// OneMoreTechie navbar — 6 tabs, 4 dropdowns, dark/light toggle, mobile menu.
---

<nav id="omt-nav">
  <div class="wrap">
    <div class="nav-inner">
      <a class="nav-logo" href="/">
        <span class="logo-one">One</span><span class="logo-more">More</span><span class="logo-techie">Techie</span>
      </a>

      <ul class="nav-links">
        <li><a href="/">Home</a></li>

        <li class="has-dropdown">
          <a href="/topics/">Topics <span class="caret">▾</span></a>
          <ul class="nav-dropdown">
            <li><a class="nav-dd-item" href="/topics/aws/">
              <span class="nav-dd-icon dd-aws">☁</span>
              <span class="nav-dd-text">
                <span class="nav-dd-label">AWS</span>
                <span class="nav-dd-desc">Services, serverless, cost &amp; FinOps</span>
              </span>
            </a></li>
            <li><a class="nav-dd-item" href="/topics/devops/">
              <span class="nav-dd-icon dd-devops">⚙</span>
              <span class="nav-dd-text">
                <span class="nav-dd-label">DevOps &amp; CI/CD</span>
