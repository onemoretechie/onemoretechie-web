---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, TOPIC_PILLARS } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, topic, type, youtube_url, github_repo, github_path, tags } = Astro.props;

const pillar = TOPIC_PILLARS.find((p) => p.slug === topic);
const typeLabel: Record<string, string> = {
  tutorial: 'Tutorial',
  runbook: 'Runbook',
  'architecture-doc': 'Architecture Doc',
  'cheat-sheet': 'Cheat Sheet',
  'interview-qa': 'Interview Q&A',
  'study-notes': 'Study Notes',
};

const ghPath = github_repo && github_path
  ? `${github_repo.replace('https://github.com/', '')}/tree/main${github_path}`
  : github_repo?.replace('https://github.com/', '');
---

<html lang="en">
  <head>
    <BaseHead title={`${title} · ${SITE_TITLE}`} description={description} />
  </head>
  <body>
    <Header />

    <main class="wrap post-wrap">
      <article class="post">
        <!-- Header block -->
        <header class="post-header">
          <div class="post-meta">
            {pillar && (
              <a class={`post-topic tc-${pillar.color}`} href={`/topics/${pillar.slug}/`}>
                <span class="post-topic-icon">{pillar.icon}</span>
                {pillar.label}
              </a>
            )}
            {type && <span class="post-type">{typeLabel[type] ?? type}</span>}
            <span class="post-date">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="post-updated"> · updated <FormattedDate date={updatedDate} /></span>
              )}
            </span>
          </div>

          <h1 class="post-title">{title}</h1>
          <p class="post-lede">{description}</p>

          {heroImage && (
            <div class="post-hero">
              <Image src={heroImage} alt="" widths={[720, 1080, 1440]} sizes="(max-width: 720px) 100vw, 900px" />
            </div>
          )}

          {(youtube_url || github_repo) && (
            <div class="post-media">
              {youtube_url && (
                <a class="media-btn" href={youtube_url} target="_blank" rel="noopener">
                  <span class="media-icon">▶</span>
                  <span>
                    <span class="media-label">Watch on YouTube</span>
                    <span class="media-sub">Video walkthrough</span>
                  </span>
                </a>
              )}
              {github_repo && (
                <a class="media-btn" href={github_repo} target="_blank" rel="noopener">
                  <span class="media-icon">◍</span>
                  <span>
                    <span class="media-label">Code on GitHub</span>
                    <span class="media-sub">{ghPath}</span>
                  </span>
                </a>
              )}
            </div>
          )}
        </header>

        <!-- Body -->
        <div class="prose">
          <slot />
        </div>

        <!-- Footer block -->
        <footer class="post-footer">
          {tags && tags.length > 0 && (
            <div class="post-tags">
              {tags.map((t) => <span class="post-tag">#{t}</span>)}
            </div>
          )}

          {(youtube_url || github_repo) && (
            <div class="post-media post-media-bottom">
              {youtube_url && (
                <a class="media-btn" href={youtube_url} target="_blank" rel="noopener">
                  <span class="media-icon">▶</span>
                  <span>
                    <span class="media-label">Watch on YouTube</span>
                    <span class="media-sub">Video walkthrough</span>
                  </span>
                </a>
              )}
              {github_repo && (
                <a class="media-btn" href={github_repo} target="_blank" rel="noopener">
                  <span class="media-icon">◍</span>
                  <span>
                    <span class="media-label">Code on GitHub</span>
                    <span class="media-sub">{ghPath}</span>
                  </span>
                </a>
              )}
            </div>
          )}

          <div class="post-nav">
            <a class="btn-outline" href="/blog/">← All posts</a>
            {pillar && (
              <a class="btn-primary" href={`/topics/${pillar.slug}/`}>More on {pillar.label} →</a>
            )}
          </div>
        </footer>
      </article>
    </main>

    <Footer />

    <style>
      .post-wrap {
        padding: 3rem 2rem 4rem;
        max-width: 900px;
      }
      .post-header {
        margin-bottom: 2.5rem;
      }
      .post-meta {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
      }
      .post-topic {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: var(--fh);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 100px;
        text-decoration: none;
        border: 1px solid;
      }
      .post-topic-icon { font-size: 0.85rem; }
      .tc-orange { color: var(--orange); background: rgba(251, 146, 60, 0.10); border-color: rgba(251, 146, 60, 0.24); }
      .tc-cyan   { color: var(--accent); background: var(--adim);              border-color: var(--abdr); }
      .tc-purple { color: var(--purple); background: rgba(167, 139, 250, 0.10); border-color: rgba(167, 139, 250, 0.24); }
      .tc-red    { color: var(--red);    background: rgba(248, 113, 113, 0.10); border-color: rgba(248, 113, 113, 0.24); }
      .tc-blue   { color: var(--blue);   background: rgba(96, 165, 250, 0.10);  border-color: rgba(96, 165, 250, 0.24); }

      .post-type {
        font-family: var(--fh);
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text3);
        padding: 4px 10px;
        border-radius: 100px;
        border: 1px solid var(--line2);
      }
      .post-date {
        font-size: 0.75rem;
        color: var(--text3);
        font-family: var(--fm);
      }
      .post-updated {
        color: var(--text3);
      }

      .post-title {
        font-family: var(--fh);
        font-size: clamp(1.8rem, 4vw, 2.6rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.15;
        color: var(--text);
        margin: 0 0 0.85rem;
      }
      .post-lede {
        font-size: 1.1rem;
        color: var(--text2);
        line-height: 1.7;
        max-width: 720px;
      }

      .post-hero {
        margin-top: 2rem;
        border-radius: var(--rl);
        overflow: hidden;
        border: 1px solid var(--line2);
      }
      .post-hero :global(img) {
        width: 100%;
        height: auto;
        display: block;
      }

      /* Media buttons (YouTube / GitHub) — reuses same visual as topic pillar page */
      .post-media {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
        margin-top: 1.75rem;
      }
      .post-media-bottom { margin: 2.5rem 0 0; }

      .media-btn {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        padding: 0.85rem 1rem;
        border: 1px solid var(--line2);
        border-radius: var(--r);
        background: var(--bg3);
        text-decoration: none;
        color: var(--text);
        transition: border-color 0.18s, background 0.18s;
      }
      .media-btn:hover {
        border-color: var(--abdr);
        background: var(--bg4);
        color: var(--text);
      }
      .media-icon {
        width: 32px; height: 32px;
        border-radius: var(--r);
        display: flex; align-items: center; justify-content: center;
        background: var(--adim);
        color: var(--accent);
        font-size: 14px;
        flex-shrink: 0;
      }
      .media-label {
        display: block;
        font-family: var(--fh);
        font-weight: 600;
        font-size: 0.9rem;
      }
      .media-sub {
        display: block;
        font-size: 0.7rem;
        color: var(--text3);
        margin-top: 2px;
        font-family: var(--fm);
        word-break: break-all;
      }

      /* Footer block */
      .post-footer {
        margin-top: 3.5rem;
        padding-top: 2rem;
        border-top: 1px solid var(--line);
      }
      .post-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
      }
      .post-tag {
        font-family: var(--fm);
        font-size: 0.72rem;
        color: var(--text3);
        padding: 3px 10px;
        border-radius: 100px;
        border: 1px solid var(--line2);
      }
      .post-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-top: 2rem;
        flex-wrap: wrap;
      }

      @media (max-width: 720px) {
        .post-media { grid-template-columns: 1fr; }
        .post-title { font-size: 1.8rem; }
        .post-lede { font-size: 1rem; }
      }
    </style>
  </body>
</html>
